generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum SystemRole {
  SUPER_ADMIN
  SUPPORT
  USER
}

enum OrganizationType {
  SCHOOL
  COLLEGE
  COACHING_CLASS
  UNIVERSITY
  KINDERGARTEN
  TRAINING_INSTITUTE
  OTHER
}

enum PlanType {
  FREE
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum MembershipRole {
  OWNER
  ORG_ADMIN
  BRANCH_ADMIN
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  STAFF
  GUEST
}

enum MembershipStatus {
  INVITED
  ACTIVE
  INACTIVE
  REVOKED
  DECLINED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRANSFERRED
  DROPPED
  GRADUATED
  ALUMNI
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
  RETIRED
}

//////////////////////////////////////////////////////
// BETTER AUTH MODELS
//////////////////////////////////////////////////////

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?

  isActive      Boolean    @default(true)
  systemRole    SystemRole @default(USER)

  accounts      Account[]
  sessions      Session[]
  verifications Verification[]

  memberships   Membership[]
  createdInvites MembershipInvite[] @relation("InviteCreatedBy")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([systemRole])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String   @id @default(cuid())
  userId                String
  providerId            String
  accountId             String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@index([identifier])
  @@index([expiresAt])
}

//////////////////////////////////////////////////////
// TENANT HIERARCHY
//////////////////////////////////////////////////////

model Institution {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  logo          String?
  isActive      Boolean        @default(true)

  organizations Organization[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Organization {
  id                String            @id @default(cuid())
  institutionId     String?
  institution       Institution?      @relation(fields: [institutionId], references: [id], onDelete: SetNull)

  name              String
  slug              String            @unique
  logo              String?
  organizationType  OrganizationType?

  contactEmail      String?
  contactPhone      String?
  website           String?

  isActive          Boolean           @default(true)
  isPaid            Boolean           @default(false)
  plan              PlanType          @default(STANDARD)
  planStartedAt     DateTime?
  planExpiresAt     DateTime?
  walletBalance     Int               @default(0)

  establishedYear   Int?
  createdByUserId   String?

  memberships       Membership[]
  invites           MembershipInvite[]
  branches          Branch[]
  rolePermissions   RolePermission[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([institutionId])
  @@index([slug])
}

model Branch {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name             String
  slug             String
  code             String?
  logo             String?

  email            String?
  phone            String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  country          String?
  postalCode       String?

  isActive         Boolean        @default(true)
  isMainBranch     Boolean        @default(false)

  memberships      Membership[]
  invites          MembershipInvite[]
  students         Student[]
  teachers         Teacher[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([organizationId, slug])
  @@unique([organizationId, code])
  @@index([organizationId])
}

//////////////////////////////////////////////////////
// MEMBERSHIP / ACCESS
//////////////////////////////////////////////////////

model Membership {
  id               String            @id @default(cuid())
  userId           String
  organizationId   String
  branchId         String?

  role             MembershipRole
  status           MembershipStatus  @default(ACTIVE)

  isDefault        Boolean           @default(false)
  customPermissions String[]

  invitedByUserId  String?
  acceptedAt       DateTime?
  revokedAt        DateTime?

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)

  studentProfile   Student?
  teacherProfile   Teacher?
  parentProfile    Parent?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([userId, organizationId, branchId, role])
  @@index([userId, status])
  @@index([organizationId, role])
  @@index([branchId, role])
}

model MembershipInvite {
  id               String            @id @default(cuid())
  organizationId   String
  branchId         String?
  email            String
  role             MembershipRole
  status           MembershipStatus  @default(INVITED)

  token            String            @unique
  customPermissions String[]

  invitedByUserId  String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  invitedBy        User?             @relation("InviteCreatedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([organizationId, role])
  @@index([branchId, role])
  @@index([email])
  @@index([expiresAt])
}

//////////////////////////////////////////////////////
// PERMISSIONS
//////////////////////////////////////////////////////

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?

  roleMappings RolePermissionMap[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  id             String            @id @default(cuid())
  organizationId String?
  role           MembershipRole

  organization   Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions    RolePermissionMap[]

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, role])
  @@index([role])
}

model RolePermissionMap {
  id               String         @id @default(cuid())
  rolePermissionId String
  permissionId     String

  rolePermission   RolePermission @relation(fields: [rolePermissionId], references: [id], onDelete: Cascade)
  permission       Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([rolePermissionId, permissionId])
  @@index([permissionId])
}

//////////////////////////////////////////////////////
// DOMAIN PROFILES
//////////////////////////////////////////////////////

model Student {
  id               String         @id @default(cuid())
  membershipId     String         @unique
  organizationId   String
  branchId         String?

  firstName        String
  lastName         String
  middleName       String?
  fullName         String?
  motherName       String?

  admissionDate    DateTime?
  dateOfBirth      DateTime
  gender           Gender
  status           StudentStatus  @default(ACTIVE)

  rollNumber       String
  email            String?
  phoneNumber      String?
  whatsAppNumber   String?
  emergencyContact String?
  address          String?
  profileImage     String?

  membership       Membership     @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch           Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)

  parents          ParentStudent[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([organizationId, rollNumber])
  @@index([branchId])
  @@index([email])
  @@index([phoneNumber])
}

model Teacher {
  id                 String           @id @default(cuid())
  membershipId       String           @unique
  organizationId     String
  branchId           String?

  employeeCode       String?
  employmentStatus   EmploymentStatus @default(ACTIVE)
  isActive           Boolean          @default(true)
  joinedAt           DateTime?
  leavingAt          DateTime?

  contactEmail       String?
  contactPhone       String?
  address            String?
  city               String?
  state              String?
  dateOfBirth        DateTime?

  qualification      String?
  experienceInYears  Int?
  resumeUrl          String?
  bio                String?

  membership         Membership       @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch             Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([organizationId, employeeCode])
  @@index([branchId])
  @@index([organizationId, employmentStatus])
}

model Parent {
  id               String          @id @default(cuid())
  membershipId     String          @unique

  firstName        String
  lastName         String
  phoneNumber      String?
  whatsAppNumber   String?

  membership       Membership      @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  students         ParentStudent[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ParentStudent {
  id             String   @id @default(cuid())
  parentId       String
  studentId      String
  relationship   String
  isPrimary      Boolean  @default(false)

  parent         Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([parentId, studentId])
  @@index([studentId])
  @@index([relationship])
}
