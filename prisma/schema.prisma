generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  engineType             = "client"
  runtime                = "vercel-edge"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  previewFeatures        = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  FREE
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum PlanCode {
  STARTER
  GROWTH
  SCALE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum BillingMetric {
  STUDENT
  FLAT
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
  EXPIRED
}

enum OfferType {
  EARLY_BIRD
  TRIAL
  ANNUAL
  MANUAL
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
}

enum SubscriptionPaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  CANCELLED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  INACTIVE
  SUSPENDED
  PENDING
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  profileImage  String   @map("image")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // App-specific fields
  firstName String
  lastName  String
  isActive  Boolean @default(true)

  // BetterAuth relations
  accounts        Account[]
  sessions        Session[]
  sentInvitations Invitation[]

  // Memberships - user can belong to multiple organizations
  memberships Membership[]

  // Institution ownership
  ownedInstitutions Institution[]

  // Profile relations
  teacher Teacher?
  student Student?
  parents Parent[]

  feePayment    FeePayment[]
  notifications Notification[]
  leave         Leave[]
  leadActivity  LeadActivity[]
  assignedLeads Lead[]         @relation("LeadAssignedTo")
  createdLeads  Lead[]         @relation("LeadCreatedBy")
  deviceTokens  DeviceToken[]

  @@index([email])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  providerId            String // "credential", "google", etc.
  accountId             String // email for credentials, provider user ID for OAuth
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?   @db.Text
  password              String? // hashed password for credential accounts

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id                   String   @id @default(cuid())
  token                String   @unique
  userId               String
  expiresAt            DateTime
  ipAddress            String?
  userAgent            String?
  activeOrganizationId String? // BetterAuth org plugin — tracks current workspace

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

// INSTITUTION (Trust/Group/Brand - Parent)
// Owns multiple Organizations

enum InstitutionType {
  TRUST // Education trust/group
  GROUP // Multi-brand group
  BRAND // Single brand
  SINGLE // Individual owner
}

model Institution {
  id          String          @id @default(cuid())
  name        String // "Delhi Public School Trust"
  slug        String          @unique
  logo        String?
  description String?
  type        InstitutionType @default(SINGLE)

  contactEmail String?
  contactPhone String?
  website      String?
  address      String?
  city         String?
  state        String?
  pinCode      String?

  ownerId  String
  isActive Boolean @default(true)

  isPaid        Boolean   @default(false)
  plan          PlanType  @default(STANDARD)
  planStartedAt DateTime?
  planExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id])
  organizations Organization[]

  @@index([ownerId])
  @@index([slug])
  @@index([isActive])
}

enum OrganizationType {
  SCHOOL
  COLLEGE
  COACHING_CLASS
  UNIVERSITY
  KINDERGARTEN
  TRAINING_INSTITUTE
  OTHER
}

enum StudentStatus {
  ACTIVE // Currently studying
  INACTIVE // Temporarily inactive (leave, unpaid fees, etc.)
  SUSPENDED // Disciplinary action
  TRANSFERRED // Moved to another school
  DROPPED // Left without completing
  GRADUATED // Completed education
  ALUMNI // Historical record (optional)
}

model Organization {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  logo     String?
  metadata String?

  // Institution relation (optional - for multi-org owners)
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])

  contactEmail String? // admin or billing contact
  contactPhone String? // admin or billing contact
  website      String?

  isActive         Boolean           @default(true)
  isPaid           Boolean           @default(false)
  plan             PlanType          @default(STANDARD)
  planStartedAt    DateTime?
  planExpiresAt    DateTime?
  walletBalance    Int               @default(10000) // Paise  (100₹)
  // Limits (can be used to restrict features based on plan)
  maxStudents      Int? // set limits per plan
  organizationType OrganizationType?

  notices              Notice[]
  Student              Student[]
  StudentDocument      StudentDocument[]
  Grade                Grade[]
  Section              Section[]
  Fee                  Fee[]
  FeeCategory          FeeCategory[]
  FeePayment           FeePayment[]
  AcademicCalendar     AcademicCalendar[]
  AnonymousComplaint   AnonymousComplaint[]
  Teacher              Teacher[]
  Subject              Subject[]
  TeachingAssignment   TeachingAssignment[]
  AcademicYear         AcademicYear[]
  scheduledJob         ScheduledJob[]
  leaves               Leave[]
  examSessions         ExamSession[]
  exam                 Exam[]
  hallTicket           HallTicket[]
  leads                Lead[]
  feeSenseAgent        FeeSenseAgent?
  notificationSettings NotificationSetting[]
  notifications        Notification[]
  NotificationLog      NotificationLog[]
  certificates         Certificate[]
  reportCards          ReportCard[]
  parents              Parent[]

  // Branches - physical locations
  // branches    Branch[]
  memberships Membership[]
  invitations Invitation[]

  establishedYear Int?
  createdBy       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  metaIntegration MetaIntegration?

  gradingScales GradingScale[]
  idCards       IdCard[]
  subscriptions Subscription[]

  @@index([id])
  @@index([slug])
  @@index([institutionId])
}

model Plan {
  id            String        @id @default(cuid())
  code          PlanCode      @unique
  name          String
  description   String?
  billingMetric BillingMetric
  monthlyPrice  Int?
  annualPrice   Int?
  studentLimit  Int?
  isPublic      Boolean       @default(true)
  isActive      Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  subscriptions Subscription[]

  @@index([isPublic, isActive])
  @@index([sortOrder])
}

model Offer {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  type            OfferType
  description     String?
  discountPercent Int?
  fixedPrice      Int?
  trialDays       Int?
  maxRedemptions  Int?
  redeemedCount   Int       @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscriptions Subscription[]

  @@index([type, isActive])
  @@index([startsAt, endsAt])
}

model Subscription {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId         String
  plan           Plan         @relation(fields: [planId], references: [id])
  offerId        String?
  offer          Offer?       @relation(fields: [offerId], references: [id])

  status        SubscriptionStatus @default(TRIALING)
  billingCycle  BillingCycle       @default(MONTHLY)
  billingMetric BillingMetric
  price         Int?
  studentLimit  Int?
  studentCount  Int                @default(0)

  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
  payments SubscriptionPayment[]
  events   BillingEvent[]

  @@index([organizationId, status])
  @@index([planId])
  @@index([offerId])
  @@index([currentPeriodEnd])
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  organizationId String

  periodStart  DateTime
  periodEnd    DateTime
  studentCount Int
  subtotal     Int
  discount     Int           @default(0)
  usageAmount  Int           @default(0)
  total        Int
  status       InvoiceStatus @default(OPEN)
  dueAt        DateTime?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  payments SubscriptionPayment[]

  @@index([organizationId, status])
  @@index([subscriptionId])
  @@index([periodStart, periodEnd])
}

model SubscriptionPayment {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceId      String?
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id])

  provider          String
  providerOrderId   String?
  providerPaymentId String?
  amount            Int
  status            SubscriptionPaymentStatus @default(PENDING)
  rawPayload        Json?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([subscriptionId, status])
  @@index([invoiceId])
  @@index([providerOrderId])
  @@index([providerPaymentId])
}

model BillingEvent {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  type           String
  message        String?
  metadata       Json?
  createdBy      String?
  createdAt      DateTime     @default(now())

  @@index([subscriptionId, createdAt])
  @@index([type])
}

