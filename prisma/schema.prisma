  // Lead scoring for prioritization (0-100)
  score Int @default(0)

  // ===== Assignment & Ownership =====
  assignedToUserId String?
  assignedTo       User?     @relation("LeadAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  assignedAt       DateTime?

  // ===== Follow-up Tracking =====
  nextFollowUpAt  DateTime?
  lastContactedAt DateTime?
  followUpCount   Int       @default(0)

  // ===== Conversion Tracking =====
  convertedAt          DateTime?
  // Uncomment when Student model is ready
  convertedToStudentId String?   @unique
  convertedToStudent   Student?  @relation("LeadToStudent", fields: [convertedToStudentId], references: [id])
  // Additional Info
  notes                String?
  requirements         String[] // ["Transportation", "Hostel", "Scholarship"]
  budgetRange          String? // "50k-1L", "1L-2L", etc.

  // Reason for closure (required for NOT_INTERESTED, INVALID)
  closureReason String?

  // Relations
  activities              LeadActivity[]
  communicationPreference LeadCommunicationPreference[]

  // ===== Audit Fields =====
  createdByUserId String?
  createdBy       User?   @relation("LeadCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status, phone])
  @@index([createdByUserId, nextFollowUpAt])
  @@index([source, createdAt])
}

model LeadActivity {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id])

  // Activity Details
  type          LeadActivityType
  title         String // "Called parent", "Sent brochure", "School visit"
  description   String?
  outcome       String? // "Interested", "Not reachable", "Will visit next week"
  sentiment     Sentiment?
  // When & Who
  performedById String?
  performedBy   User?            @relation(fields: [performedById], references: [id])
  performedAt   DateTime         @default(now())

  // Next Action
  followUpDate DateTime?
  followUpNote String?

  createdAt DateTime @default(now())

  @@index([leadId, performedAt])
  @@index([performedById])
}

