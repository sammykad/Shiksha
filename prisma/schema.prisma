// One row per recipient per event.
// This is what powers the bell icon, unread count, and inbox.
// Never duplicated per channel — one row, always.
model Notification {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId    String?
  studentId String?
  parentId  String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent    Parent?  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)

  type    NotificationType
  title   String
  message String

  // entityType String?
  // entityId   String?

  isRead      Boolean   @default(false)
  readAt      DateTime?
  isDismissed Boolean   @default(false)
  dismissedAt DateTime?

  logs NotificationLog[]

  idempotencyKey String @unique @db.Text

  createdAt DateTime @default(now())

  @@index([organizationId, userId, isRead, createdAt])
  @@index([organizationId, studentId, isRead, createdAt])
  @@index([organizationId, parentId, isRead, createdAt])
  @@index([organizationId, type, createdAt])
  // @@index([entityType, entityId])
  @@index([organizationId, academicYearId, createdAt])
}

// One row per channel per send attempt.
// This is what powers billing reports, ops dashboards,
// failure alerts, and cost calculations.
// Never read by end users. Never shown in the bell.
model NotificationLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  notificationType NotificationType
  channel          NotificationChannel
  status           NotificationStatus  @default(PENDING)

  to           String?
  cost         Float   @default(0)
  units        Int     @default(1)
  retryCount   Int     @default(0)
  maxRetries   Int     @default(3)
  errorMessage String?

  idempotencyKey String @unique @db.Text

  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([organizationId, sentAt])
  @@index([organizationId, channel, status, sentAt])
  @@index([organizationId, notificationType, sentAt])
  @@index([notificationId])
}

