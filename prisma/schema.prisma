  reportCards        ReportCard[]
  // StudentDocument
  // ScheduledJob
  // NotificationLog
  // HallTicket
  // ReportCard
  // ExamResult
  // ExamEnrollment
  createdBy          String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, isCurrent])
}

