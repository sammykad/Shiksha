model MetaIntegration {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  // OAuth connection details
  metaUserId      String // Meta user ID who connected
  pageId          String @unique // Facebook Page ID (used to route webhooks)
  pageName        String // Display name e.g. "Delhi Public School"
  pageAccessToken String // Long-lived Page Access Token (encrypted at rest!)

  // Which lead forms are being synced
  subscribedFormIds String[] // Meta Lead Form IDs

  // Connection status
  isActive       Boolean   @default(true)
  connectedAt    DateTime  @default(now())
  tokenExpiresAt DateTime? // null = never expires (page tokens)
  lastSyncAt     DateTime?

  // Audit
  connectedByUserId String?
  // connectedBy    User?    @relation(fields: [connectedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId]) // critical — webhook lookup by page_id
  @@index([organizationId])
}

model FeeSenseAgent {
  id             String       @id @default(cuid())
  organizationId String       @unique // One per org
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String       @default("FeeSense AI Agent")
  description    String?      @default("Intelligent fee collection assistant that analyzes payment patterns and sends personalized reminders")

  isActive Boolean @default(true)

  capabilities             String[]
  // capabilities: [
  //       "Fetch all Fees Data and check if any fee is pending or not",
  //       "Analyzes payment patterns and identifies at-risk families",
  //       "Sends personalized payment reminders via email and SMS",
  //       "Generates daily reports with collection insights",
  //       "Schedules voice calls for high-priority overdue fees",
  //     ],
  // FeeSense-specific configuration
  riskScoreLowThreshold    Int      @default(30)
  riskScoreMediumThreshold Int      @default(60)
  riskScoreHighThreshold   Int      @default(80)
  maxNotificationAttempts  Int      @default(3)
  voiceCallThreshold       Int      @default(3) // Days overdue before call

  // Notification preferences
  enableEmailReminders Boolean @default(true)
  enableSMSReminders   Boolean @default(true)
  enableVoiceCalls     Boolean @default(false)
  enableWhatsApp       Boolean @default(false)

  // Scheduling
  runFrequency AIAgentRunFrequency @default(DAILY)
  scheduleTime String              @default("23:00") // HH:mm format

  // // AI Model config
  // aiModel     String @default("gpt-4")
  // temperature Float  @default(0.7)

  // Execution tracking
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  totalRuns      Int       @default(0)
  successfulRuns Int       @default(0)
  failedRuns     Int       @default(0)

  // Relations
  executionLogs FeeSenseExecutionLog[]
  reports       FeeSenseReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, isActive])
}

model FeeSenseExecutionLog {
  id      String        @id @default(cuid())
  agentId String
  agent   FeeSenseAgent @relation(fields: [agentId], references: [id])

  startedAt   DateTime
  completedAt DateTime?
  status      AIAgentExecutionStatus // RUNNING, SUCCESS, FAILED, PARTIAL

  // FeeSense-specific metrics
  studentsAnalyzed    Int
  remindersGenerated  Int
  emailsSent          Int
  smsSent             Int
  voiceCallsScheduled Int
  totalAmountOverdue  Float

  errorMessage String?
  errorDetails Json?

  createdAt DateTime @default(now())

  @@index([agentId, startedAt])
}

model FeeSenseReport {
  id String @id @default(cuid())

  agentId String
  agent   FeeSenseAgent @relation(fields: [agentId], references: [id])

  reportDate DateTime

  // Summary metrics
  totalStudentsAtRisk Int
  highRiskCount       Int
  mediumRiskCount     Int
  lowRiskCount        Int

  totalOverdueAmount Float
  paymentsReceived   Float // Since last report

  // Outreach summary
  emailsSent          Int
  smsSent             Int
  voiceCallsScheduled Int
  responseRate        Float?

  // Detailed insights (AI-generated)
  insights Json
  // Example: {
  //   "trends": "Payment rates down 15% this week",
  //   "recommendations": ["Focus on Grade 10 students", "Increase SMS frequency"],
  //   "topRiskStudents": [...]
  // }

  sentToEmails String[] // Admin emails where report was sent

  createdAt DateTime @default(now())

  @@unique([agentId, reportDate])
  @@index([agentId, reportDate])
}

enum AIAgentRunFrequency {
  DAILY
  WEEKLY
  MONTHLY
  ON_DEMAND
}

enum AIAgentExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

enum CalendarEventType {
  PLANNED // Standard holidays (e.g., festivals, semester breaks)
  EMERGENCY // Emergency closures (e.g., weather, strikes)
  INSTITUTION_SPECIFIC // Custom events (e.g., college fests, coaching workshops)
}

model AcademicCalendar {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Event details
  name      String // e.g., "Diwali Break", "Emergency Closure", "Tech Fest"
  startDate DateTime // Start date of the holiday or event
  endDate   DateTime // End date of the holiday or event

  // Event categorization
  type           CalendarEventType // PLANNED, SUDDEN, INSTITUTION_SPECIFIC
  reason         String? // e.g., "Festival", "Weather Emergency", "Exam Prep"
  isRecurring    Boolean           @default(false) // Whether the event repeats annually
  createdBy      String // ID of the user who created the entry (admin/teacher)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  academicYear   AcademicYear?     @relation(fields: [academicYearId], references: [id])
  academicYearId String?

  @@unique([organizationId, startDate, endDate]) // Prevent duplicate entries for the same date range
  @@index([organizationId, startDate, endDate]) // Optimize queries for date ranges
  @@index([academicYearId])
}

enum YearType {
  ANNUAL // For Schools (April–March)
  SEMESTER // For Colleges/Universities
  TRIMESTER // For IB/International Schools
  BATCH // For Coaching/Training Programs
}

// #   Planing to change to fiscalYear 
